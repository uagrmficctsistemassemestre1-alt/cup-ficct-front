# URL base de la API Laravel (incluye el sufijo /api). Ej: http://localhost:8000/api
# La usa el navegador (cliente).
NEXT_PUBLIC_API_URL=

# URL de la API para llamadas server-side (proxys de archivos: foto/título/comprobante/recibo).
# Solo necesaria en Docker, donde el server de Next no alcanza el backend por localhost.
# Ej: http://host.docker.internal:8000/api . Si se omite, usa NEXT_PUBLIC_API_URL.
BACKEND_API_URL=
